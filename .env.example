# -- Gemini --------------------------------------------------------------------
GEMINI_API_KEY=                    # Get from Google AI Studio
GEMINI_MODEL=gemini-1.5-flash      # Do not change unless you know why
GEMINI_FALLBACK_MODEL=             # Optional secondary model for failover
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_DELAY_MS=400
GEMINI_INPUT_COST_PER_1M_TOKENS=0  # Optional cost hook; set from current provider pricing
GEMINI_OUTPUT_COST_PER_1M_TOKENS=0 # Optional cost hook; set from current provider pricing
AI_DAILY_REQUEST_LIMIT=100
AI_MAX_PROMPT_TOKENS=20000
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_MS=30000
GEMINI_STREAM_TIMEOUT_MS=90000
UPSTREAM_CALL_TIMEOUT_MS=15000

# -- Firebase (Admin SDK service account) --------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=              # Keep the \n newlines; wrap in double quotes

# -- Redis ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
CACHE_BACKEND=memory               # memory-first; redis shape is reserved for future wiring

# -- External APIs --------------------------------------------------------------
OPENWEATHER_API_KEY=               # openweathermap.org; free tier is enough
GOOGLE_MAPS_API_KEY=               # Enable: Geocoding API + Places API

# -- App -----------------------------------------------------------------------
PORT=3001
NODE_ENV=development               # development | production | test
CORS_ORIGIN=http://localhost:5173  # Frontend URL
API_RATE_LIMIT_PER_MINUTE=60
ITINERARY_RATE_LIMIT_PER_MINUTE=5
