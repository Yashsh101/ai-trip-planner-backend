# Production environment template.
# Do not commit real values. Set these in your host's secret manager / environment UI.

NODE_ENV=production
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=https://your-frontend.example.com

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_FALLBACK_MODEL=
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_DELAY_MS=400
GEMINI_INPUT_COST_PER_1M_TOKENS=0
GEMINI_OUTPUT_COST_PER_1M_TOKENS=0
AI_DAILY_REQUEST_LIMIT=100
AI_MAX_PROMPT_TOKENS=20000
GEMINI_STREAM_TIMEOUT_MS=90000

# Reliability
UPSTREAM_CALL_TIMEOUT_MS=15000
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_MS=30000

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# External APIs
OPENWEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=

# Cache
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379

# Rate limits
API_RATE_LIMIT_PER_MINUTE=60
ITINERARY_RATE_LIMIT_PER_MINUTE=5
